# EmeraldFi Environment Variables
# Copy to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=your_helius_api_key_here
# Get free key at: https://helius.dev (100k req/month free)

# AI - Groq (Free tier: 1000 req/day)
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Telegram Bot
# Create bot at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook/telegram
TELEGRAM_BOT_USERNAME=YourBotUsername
# Generate random secret: openssl rand -hex 32
TELEGRAM_SECRET_TOKEN=your_random_secret_here

# EmeraldFi Token
EMFI_TOKEN_ADDRESS=your_token_address_after_pump_fun_launch

# Database
DB_PATH=./emeraldfi.db
